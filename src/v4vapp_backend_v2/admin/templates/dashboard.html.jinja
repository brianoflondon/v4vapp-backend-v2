{% extends "base.html.jinja" %}

{% block page_actions %}
<div class="d-flex gap-2">
    <a href="/admin/v4vconfig" class="btn btn-primary">
        <i class="bi bi-gear me-1"></i>
        V4V Config
    </a>
    <a href="/admin/docs" class="btn btn-outline-secondary" target="_blank">
        <i class="bi bi-book me-1"></i>
        API Docs
    </a>
</div>
{% endblock %}

{% block content %}
<div class="row">
    <!-- Quick Stats -->
    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-body text-center">
                <div class="h1 text-primary mb-2">👥</div>
                <h5 class="card-title">Account Balances</h5>
                <p class="card-text text-muted">View and manage account balances</p>
                <a href="/admin/accounts" class="btn btn-primary btn-sm">View Accounts</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-body text-center">
                <div class="h1 text-info mb-2">📊</div>
                <h5 class="card-title">Financial Reports</h5>
                <p class="card-text text-muted">Generate and view financial reports</p>
                <a href="/admin/financial-reports" class="btn btn-info btn-sm" target="_blank">View Reports</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-body text-center">
                <div class="h1 text-success mb-2">❤️</div>
                <h5 class="card-title">System Health</h5>
                <p class="card-text text-muted">Check system status</p>
                <a href="/admin/health" class="btn btn-success btn-sm" target="_blank">Health Check</a>
            </div>
        </div>
    </div>
</div>

<!-- System Information -->
<div class="row">
    <div class="col-lg-12 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">🏠 System Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <h6 class="text-muted">Admin Interface</h6>
                        <ul class="list-unstyled">
                            <li><strong>Admin Version:</strong> {{ admin_info.admin_version }}</li>
                            <li><strong>Project Version:</strong> {{ admin_info.project_version }}</li>
                            <li><strong>Local Machine Name:</strong> {{ admin_info.local_machine_name }}</li>
                            <li><strong>Config File:</strong> <code>{{ admin_info.config_file }}</code></li>
                            <li><strong>Server Account:</strong> <code>{{ admin_info.server_account }}</code>
                                <span id="server-balance-check">⏳</span>
                            </li>
                            <li><strong>Load Time:</strong> <span id="load-time">loading&hellip;</span></li>
                        </ul>
                    </div>
                    <div class="col-md-4" id="hive-balances-section">
                        <h6 class="text-muted">Hive Balances</h6>
                        <div class="d-flex align-items-center text-muted small">
                            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                            Loading Hive balances&hellip;
                        </div>
                    </div>
                    <div class="col-md-4" id="lnd-info-section">
                        <h6 class="text-muted">LND Balances</h6>
                        <div class="d-flex align-items-center text-muted small">
                            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                            Loading LND balances&hellip;
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Financial Summary Cards (loaded async) -->
<div class="row mb-4" id="financial-summary-section">
    <div class="col-md-6 mb-4">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="card-title mb-0">Net Income (P&amp;L)</h6>
                    <div class="fs-4 text-muted">
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        Loading&hellip;
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="card-title mb-0">Trading P&amp;L</h6>
                    <div class="fs-4 text-muted">
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        Loading&hellip;
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Getting Started -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">🚀 Getting Started</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <div class="text-center mb-3">
                            <div class="h1 text-primary">1️⃣</div>
                            <h6>Configure V4VApp</h6>
                            <p class="text-muted small">Set up your V4VApp configuration including fees, limits, and
                                gateway settings.</p>
                            <a href="/admin/v4vconfig" class="btn btn-outline-primary btn-sm">Configure Now</a>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-center mb-3">
                            <div class="h1 text-info">2️⃣</div>
                            <h6>Monitor System</h6>
                            <p class="text-muted small">Keep track of your system's health and performance metrics.</p>
                            <a href="/admin/health" class="btn btn-outline-info btn-sm" target="_blank">Check Health</a>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-center mb-3">
                            <div class="h1 text-success">3️⃣</div>
                            <h6>Explore API</h6>
                            <p class="text-muted small">Use the REST API for programmatic access to admin functions.</p>
                            <a href="/admin/docs" class="btn btn-outline-success btn-sm" target="_blank">API Docs</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
    // Track load start time
    const _dashLoadStart = performance.now();

    // Helper: escape HTML to prevent XSS
    function escHtml(str) {
        const d = document.createElement('div');
        d.textContent = str;
        return d.innerHTML;
    }

    // --- Render helpers ---

    function renderHiveBalances(data) {
        const section = document.getElementById('hive-balances-section');
        const balances = data.balances || {};
        const keys = Object.keys(balances);
        if (keys.length === 0) {
            section.innerHTML = '<h6 class="text-muted">Hive Balances</h6>'
                + '<div class="small text-muted">No hive accounts configured.</div>';
            return;
        }
        let html = '<h6 class="text-muted">Hive Balances</h6>'
            + '<div class="table-responsive"><table class="table table-borderless table-sm mb-0">'
            + '<thead><tr><th>Account</th><th class="text-end">HIVE</th><th class="text-end">HBD</th></tr></thead><tbody>';
        for (const acc of keys) {
            const b = balances[acc];
            if (b.error) {
                html += '<tr><td><strong>' + escHtml(acc) + '</strong></td>'
                    + '<td colspan="2" class="text-danger small">Error: ' + escHtml(b.error) + '</td></tr>';
            } else {
                html += '<tr><td><strong>' + escHtml(acc) + '</strong></td>'
                    + '<td class="text-end">' + escHtml(b.HIVE_fmt || '0.000') + '</td>'
                    + '<td class="text-end">' + escHtml(b.HBD_fmt || '0.000') + '</td></tr>';
            }
        }
        html += '</tbody></table></div>';
        section.innerHTML = html;
    }

    function renderLndInfo(data) {
        const info = data.lnd_info || {};
        document.getElementById('lnd-info-section').innerHTML =
            '<h6 class="text-muted">LND Balances</h6>'
            + '<div class="d-flex flex-column align-items-start">'
            + '<div><div class="small text-muted">Node Balance (sats)</div>'
            + '<div class="fs-5">' + escHtml(info.node_balance_fmt || 'N/A') + ' sats</div></div>'
            + '<div class="mt-3"><div class="small text-muted">External Lightning Payments (sats)</div>'
            + '<div class="fs-5">' + escHtml(info.external_sats_fmt || 'N/A') + ' sats</div></div>'
            + '<div class="mt-3"><div class="small text-muted">Treasury Lightning (sats)</div>'
            + '<div class="fs-5">' + escHtml(info.treasury_sats_fmt || 'N/A') + ' sats</div></div>'
            + '<div class="mt-3"><strong>Delta:</strong> ' + escHtml(info.delta_fmt || 'N/A') + ' sats</div>'
            + '</div>';
    }

    function renderFinancialSummary(data) {
        const section = document.getElementById('financial-summary-section');
        const pl = data.profit_loss_usd != null ? data.profit_loss_usd : 0;
        const tp = data.trading_pnl_usd != null ? data.trading_pnl_usd : 0;
        const plClass = pl >= 0 ? 'bg-primary text-white' : 'bg-warning text-dark';
        const plIcon = pl >= 0 ? 'fa-thumbs-up' : 'fa-thumbs-down';
        const tpClass = tp >= 0 ? 'bg-secondary text-white' : 'bg-danger text-white';
        const tpIcon = tp >= 0 ? 'fa-chart-line' : 'fa-chart-bar';
        section.innerHTML =
            '<div class="col-md-6 mb-4"><div class="card ' + plClass + '">'
            + '<div class="card-body d-flex justify-content-between align-items-center">'
            + '<div><h6 class="card-title mb-0">Net Income (P&amp;L)</h6>'
            + '<div class="fs-4">' + escHtml(pl.toFixed(2)) + ' USD</div></div>'
            + '<div><i class="fas ' + plIcon + ' fa-2x"></i></div></div></div></div>'
            + '<div class="col-md-6 mb-4"><div class="card ' + tpClass + '">'
            + '<div class="card-body d-flex justify-content-between align-items-center">'
            + '<div><h6 class="card-title mb-0">Trading P&amp;L</h6>'
            + '<div class="fs-4">' + escHtml(tp.toFixed(2)) + ' USD</div></div>'
            + '<div><i class="fas ' + tpIcon + ' fa-2x"></i></div></div></div></div>';
    }

    function renderSanity(data) {
        // Update server balance check icon
        const checkEl = document.getElementById('server-balance-check');
        if (checkEl && data.server_balance_check) {
            checkEl.textContent = data.server_balance_check.icon || '❓';
        }

        // Update sidebar sanity results
        const sidebarEl = document.getElementById('sanity-sidebar-placeholder');
        if (sidebarEl && data.sanity_results && data.sanity_results.length > 0) {
            let html = '<h6 class="text-white">Sanity Checks</h6>'
                + '<div class="bg-white text-dark p-2 rounded" style="font-size:0.75rem; max-height:200px; overflow-y:auto;">';
            for (const r of data.sanity_results) {
                const firstNewlineIndex = r.details.indexOf('\n');
                const summaryLine = firstNewlineIndex === -1 ? r.details : r.details.slice(0, firstNewlineIndex);
                const detailText = firstNewlineIndex === -1 ? '' : r.details.slice(firstNewlineIndex + 1);
                html += '<div class="mb-1"><strong>' + escHtml(summaryLine) + '</strong>';
                if (firstNewlineIndex !== -1) {
                    html += '<pre class="mb-0" style="white-space:pre-wrap;">' + escHtml(detailText) + '</pre>';
                }
                html += '</div>';
            }
            html += '</div>';
            sidebarEl.innerHTML = html;
        }

        const alertArea = document.getElementById('async-alerts-area');

        // Show sanity failure alert + modal
        if (data.sanity_failed && data.sanity_failed.length > 0 && alertArea) {
            alertArea.insertAdjacentHTML('beforeend',
                '<div class="alert alert-warning alert-dismissible no-auto-dismiss fade show" role="alert">'
                + '<strong>⚠️ Failed Sanity Checks</strong>'
                + ' <button type="button" class="btn btn-sm btn-outline-warning ms-2" data-bs-toggle="modal" data-bs-target="#sanityChecksModal">'
                + 'View Details (' + data.sanity_failed.length + ')</button>'
                + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>');
            let modalHtml = '<div class="modal fade" id="sanityChecksModal" tabindex="-1" aria-hidden="true">'
                + '<div class="modal-dialog modal-lg"><div class="modal-content">'
                + '<div class="modal-header"><h5 class="modal-title">'
                + '<i class="bi bi-exclamation-triangle text-warning me-2"></i>'
                + 'Sanity Check Results (' + data.sanity_failed.length + ')</h5>'
                + '<button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>'
                + '<div class="modal-body"><p class="text-muted mb-3">The following sanity checks have reported issues:</p>'
                + '<div class="list-group">';
            for (const f of data.sanity_failed) {
                modalHtml += '<div class="list-group-item"><div class="d-flex align-items-start">'
                    + '<div class="flex-grow-1"><strong>' + escHtml(f.name) + '</strong>'
                    + '<p class="mb-0">' + escHtml(f.details) + '</p></div>'
                    + '<div><span class="badge bg-danger">Failed</span></div></div></div>';
            }
            modalHtml += '</div></div><div class="modal-footer">'
                + '<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>'
                + '</div></div></div></div>';
            document.body.insertAdjacentHTML('beforeend', modalHtml);
        }

        // Show pending transactions alert + modal
        if (data.pending_transactions && data.pending_transactions.length > 0 && alertArea) {
            const count = data.pending_transactions.length;
            alertArea.insertAdjacentHTML('beforeend',
                '<div class="alert alert-warning alert-dismissible no-auto-dismiss fade show" role="alert">'
                + '<strong>⚠️ Pending Transactions</strong>'
                + ' <button type="button" class="btn btn-sm btn-outline-warning ms-2" data-bs-toggle="modal" data-bs-target="#pendingTransactionsModal">'
                + 'View Details (' + count + ')</button>'
                + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>');
            let modalHtml = '<div class="modal fade" id="pendingTransactionsModal" tabindex="-1" aria-hidden="true">'
                + '<div class="modal-dialog modal-lg"><div class="modal-content">'
                + '<div class="modal-header"><h5 class="modal-title">'
                + '<i class="bi bi-exclamation-triangle text-warning me-2"></i>'
                + 'Pending Transactions (' + count + ')</h5>'
                + '<button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>'
                + '<div class="modal-body"><p class="text-muted mb-3">The following transactions are pending and require attention:</p>'
                + '<div class="list-group">';
            for (const t of data.pending_transactions) {
                modalHtml += '<div class="list-group-item"><div class="d-flex align-items-start">'
                    + '<div class="flex-grow-1"><code class="text-break">' + escHtml(t) + '</code></div></div></div>';
            }
            modalHtml += '</div></div><div class="modal-footer">'
                + '<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>'
                + '</div></div></div></div>';
            document.body.insertAdjacentHTML('beforeend', modalHtml);
        }

        // Update load time (sanity is the slowest, so this marks "fully loaded")
        const elapsed = ((performance.now() - _dashLoadStart) / 1000).toFixed(3);
        const loadEl = document.getElementById('load-time');
        if (loadEl) loadEl.textContent = elapsed + ' s';
    }

    // --- Staggered fetch: wave 1 (fast) then wave 2 (heavy) ---
    //
    // Wave 1: hive-balances, lnd-info, financial-summary
    //   These are relatively fast and warm the ledger cache.
    // Wave 2: sanity (heaviest, benefits from warm cache)
    //   Starts after lnd-info completes so its ledger queries can
    //   hit cached results instead of competing for cold DB reads.

    const hivePromise = fetch('/admin/api/dashboard/hive-balances')
        .then(r => r.json())
        .then(renderHiveBalances)
        .catch(err => {
            document.getElementById('hive-balances-section').innerHTML =
                '<h6 class="text-muted">Hive Balances</h6>'
                + '<div class="text-danger small">Failed to load: ' + escHtml(String(err)) + '</div>';
        });

    const lndPromise = fetch('/admin/api/dashboard/lnd-info')
        .then(r => r.json())
        .then(renderLndInfo)
        .catch(err => {
            document.getElementById('lnd-info-section').innerHTML =
                '<h6 class="text-muted">LND Balances</h6>'
                + '<div class="text-danger small">Failed to load: ' + escHtml(String(err)) + '</div>';
        });

    const finPromise = fetch('/admin/api/dashboard/financial-summary')
        .then(r => r.json())
        .then(renderFinancialSummary)
        .catch(err => {
            document.getElementById('financial-summary-section').innerHTML =
                '<div class="col-12 text-danger small">Failed to load financial summary: '
                + escHtml(String(err)) + '</div>';
        });

    // Wave 2: start sanity only after lnd-info finishes (ledger cache warm)
    lndPromise.finally(() => {
        fetch('/admin/api/dashboard/sanity')
            .then(r => r.json())
            .then(renderSanity)
            .catch(err => {
                const checkEl = document.getElementById('server-balance-check');
                if (checkEl) checkEl.textContent = '⚠️';
                const loadEl = document.getElementById('load-time');
                if (loadEl) loadEl.textContent = 'error';
            });
    });
</script>
{% endblock %}
