{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "DEV Admin Interface (Run - No Debug)",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "${workspaceFolder}/src/v4vapp_backend_v2/admin/run_admin.py",
                "--host",
                "0.0.0.0",
                "--port",
                "8080",
                "--config",
                "devhive.config.yaml"
            ],
            "options": {
                "env": {
                    "PYTHONPATH": "${workspaceFolder}/src"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": []
        }
    ]
}
